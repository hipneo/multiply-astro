<nav class="blog-nav">
  <div class="container">
    <a href="/" class="logo">Multiply<span>.</span></a>
    <div class="nav-links">
      <a href="/blog" class="nav-link">Blog</a>
      <a href="/#how" class="nav-link">How it works</a>
      <a href="/#book" class="cta-nav">Book a diagnostic</a>
    </div>
  </div>
</nav>

<style>
  .blog-nav {
    position: sticky; top: 0; left: 0; right: 0; z-index: 100;
    background: rgba(14,14,12,0.9);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid rgba(240,237,230,0.06);
  }
  .blog-nav .container {
    display: flex; justify-content: space-between; align-items: center;
    height: 64px;
  }
  .logo {
    font-family: var(--serif);
    font-size: 22px;
    color: var(--text);
    letter-spacing: -0.02em;
  }
  .logo span { color: var(--accent); }
  .nav-links { display: flex; align-items: center; gap: 2rem; }
  .nav-link {
    font-size: 14px;
    color: var(--text-dim);
    transition: color 0.2s;
  }
  .nav-link:hover { color: var(--text); }
  .cta-nav {
    font-size: 14px;
    font-weight: 500;
    color: var(--bg);
    background: var(--accent);
    padding: 8px 20px;
    border-radius: 6px;
    transition: all 0.2s;
  }
  .cta-nav:hover { background: var(--text); color: var(--bg); }
  @media (max-width: 640px) {
    .nav-link { display: none; }
  }
</style>
