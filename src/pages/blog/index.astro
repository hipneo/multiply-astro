---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_TITLE } from '../../consts';

const posts = (await getCollection('blog')).sort(
  (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead
      title={`Writing — ${SITE_TITLE}`}
      description="Marketing strategy, growth, and lessons from the trenches. For SaaS founders who want to build a real marketing engine."
    />
    <style>
      .blog-header {
        padding: 5rem 0 3.5rem;
        border-bottom: 1px solid var(--border);
        max-width: 720px;
      }
      .blog-header .section-label {
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.15em;
        color: var(--accent);
        margin-bottom: 1rem;
      }
      .blog-header h1 {
        font-family: var(--serif);
        font-size: clamp(2.2rem, 4vw, 3.2rem);
        line-height: 1.1;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 0.75rem;
      }
      .blog-header p {
        color: var(--text-dim);
        font-size: 1.05rem;
        max-width: 500px;
        line-height: 1.7;
      }
      .posts-list {
        padding: 0;
        max-width: 720px;
      }
      .post-item {
        display: block;
        padding: 2.5rem 0;
        border-bottom: 1px solid var(--border);
        transition: none;
        color: inherit;
        text-decoration: none;
      }
      .post-item:hover .post-item-title {
        color: var(--accent);
      }
      .post-item-date {
        font-size: 12px;
        font-weight: 500;
        text-transform: uppercase;
        letter-spacing: 0.1em;
        color: var(--text-faint);
        margin-bottom: 0.6rem;
      }
      .post-item-title {
        font-family: var(--serif);
        font-size: clamp(1.3rem, 2.5vw, 1.75rem);
        line-height: 1.2;
        letter-spacing: -0.02em;
        color: var(--text);
        margin-bottom: 0.6rem;
        transition: color 0.2s;
      }
      .post-item-desc {
        font-size: 0.95rem;
        color: var(--text-dim);
        line-height: 1.6;
        max-width: 600px;
      }
      .posts-section {
        padding: 0 0 5rem;
      }
    </style>
  </head>
  <body>
    <Header />
    <main>
      <div class="container">
        <div class="blog-header">
          <div class="section-label">From the desk of Liviu</div>
          <h1>Writing.</h1>
          <p>Marketing strategy, growth, and lessons from the trenches — for SaaS founders building real marketing engines.</p>
        </div>
        <div class="posts-section">
          <div class="posts-list">
            {posts.map((post) => (
              <a class="post-item" href={`/blog/${post.id}/`}>
                <div class="post-item-date">
                  <FormattedDate date={post.data.pubDate} />
                </div>
                <div class="post-item-title">{post.data.title}</div>
                {post.data.description && (
                  <div class="post-item-desc">{post.data.description}</div>
                )}
              </a>
            ))}
          </div>
        </div>
      </div>
    </main>
    <Footer />
  </body>
</html>
